{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.claude/hooks/format-on-edit.sh\"",
            "timeout": 30,
            "statusMessage": "Formatting edited TypeScript"
          }
        ]
      }
    ]
  }
}
