{
	admin off
	persist_config off
	auto_https off

	log {
		format json
	}

	servers {
		trusted_proxies static private_ranges 100.0.0.0/8
	}
}

:{$PORT:80} {
	log {
		format json
	}

	header {
		X-Content-Type-Options "nosniff"
		-Server
	}

	root * /app/frontend/dist

	encode {
		gzip
		zstd
	}

	handle /health {
		respond 200
	}

	@asset_paths path /assets /assets/*
	handle @asset_paths {
		@fingerprinted_asset {
			path_regexp ^/assets/.+-[A-Za-z0-9_-]{8,}\.[^/]+$
			file
		}
		header @fingerprinted_asset Cache-Control "public, max-age=31536000, immutable"

		file_server {
			hide /app/frontend/dist/.git /app/frontend/dist/.env*
		}
	}

	handle {
		route {
			try_files {path} {path}.html {path}/index.html /index.html

			@document `method('GET', 'HEAD') && header({'Accept': '*text/html*'}) && (path('*.html') || {file_match.type} == 'directory')`
			header @document {
				Cache-Control "max-age=0, must-revalidate"
				CDN-Cache-Control "no-store"
				Cloudflare-CDN-Cache-Control "public, max-age=60, must-revalidate"
				Cache-Tag "dinder-route-html"
			}

			file_server {
				hide /app/frontend/dist/.git /app/frontend/dist/.env*
			}
		}
	}
}
